---
const painPoints = [
  "多材质球管理混乱，换肤需要逐个替换",
  "控制器散落在 3D 视口中，操作效率低下",
  "视口帧率拉胯，动画预览卡顿严重",
  "身体比例固定，无法创造个性化角色",
  "大量依赖插件，版本兼容性差"
];

const solutions = [
  "AIO 着色器，一个材质球 management 所有部位",
  "独立 UI 面板，所有参数集中呈现",
  "极致优化架构，轻松 100fps+* 实时预览",
  "Body Shaping 系统自由调整任意形体参数",
  "核心功能零插件依赖，Append 即用，永不过时"
];
---

<div class="pt-8">
  <div class="text-center space-y-4 mb-16">
    <h2
      class="text-4xl md:text-5xl font-bold font-sans tracking-wider uppercase text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400"
    >
      Why Rig/2?
    </h2>
    <div class="w-16 h-1 bg-[#ea7601] mx-auto rounded-full"></div>
  </div>

  <div class="max-w-5xl mx-auto font-sans">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Left: Pain points -->
      <div class="space-y-6">
        <h3 class="text-2xl font-bold text-white mb-4">
          传统 Rig 的痛点
        </h3>
        <div class="space-y-4">
          {
            painPoints.map((point) => (
              <div class="flex items-start gap-3">
                <div class="mt-1 text-red-400 flex-shrink-0">✕</div>
                <p class="text-gray-400">{point}</p>
              </div>
            ))
          }
        </div>
      </div>
      <!-- Right: Solutions -->
      <div class="space-y-6">
        <h3 class="text-2xl font-bold text-[#ea7601] mb-4">
          Rig/2 的解决方案
        </h3>
        <div class="space-y-4">
          {
            solutions.map((solution) => (
              <div class="flex items-start gap-3">
                <div class="mt-1 text-[#ea7601] flex-shrink-0">✓</div>
                <p class="text-gray-300">{solution}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</div>
