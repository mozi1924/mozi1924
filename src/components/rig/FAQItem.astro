---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<div
  class="glass-card rounded-2xl p-6 hover:border-white/10 transition-colors duration-300"
>
  <h4 class="text-lg font-bold text-white mb-2">
    {question}
  </h4>
  <p class="text-gray-400 leading-relaxed">
    {answer}
  </p>
</div>
