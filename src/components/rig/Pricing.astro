---
import { Download, ShoppingCart } from "lucide-react";

const editions = [
  {
    name: "Free Edition",
    price: "$0",
    period: "/ Community Version",
    features: [
      "包含所有核心绑定逻辑",
      "AIO 着色器",
      "三种脚部模式",
      "Steve & Alex 双比例支持",
      "仅限个人/非商业项目使用"
    ],
    buttonText: "免费下载",
    isPro: false,
    badge: null,
    href: "https://assets.mozi1924.com/rig2/latest.zip"
  },
  {
    name: "Pro Edition",
    price: "Pro",
    period: "",
    features: [
      "包含 Free 版所有功能",
      "包含商业使用授权 (Commercial License)",
      "面部捕捉 (Face Mocap) 集成",
      "高级表情系统 (52 Blendshapes)",
      "优先技术支持 & 更新通道",
      "支持导入 .miframes 动作",
      "R2bb geckolib导出",
      "Rig/2 Ecosystem 完整访问权限"
    ],
    buttonText: "立即购买",
    isPro: true,
    badge: "Ultimate",
    href: "https://store.mozi1924.com/l/rig2"
  }
];
---

<div class="pt-8 font-sans max-w-5xl mx-auto">
  <div class="text-center space-y-4 mb-16">
    <h2
      class="text-4xl md:text-5xl font-bold tracking-wider uppercase text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400"
    >
      Editions
    </h2>
    <div class="w-16 h-1 bg-[#ea7601] mx-auto rounded-full"></div>
    <p class="text-gray-400 max-w-2xl mx-auto text-lg">
      选择适合你的版本，从免费社区版到完整专业版
    </p>
  </div>

  <div class="relative px-4 md:px-0">
    <!-- Mobile Arrow Navigation -->
    <button
      id="pricing-prev"
      class="md:hidden absolute left-2 top-1/2 -translate-y-1/2 z-20 bg-[#1a1a1a]/80 border border-white/10 p-2 rounded-full text-[#ea7601] shadow-lg backdrop-blur-sm opacity-0 transition-opacity"
      aria-label="Previous edition"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
    <button
      id="pricing-next"
      class="md:hidden absolute right-2 top-1/2 -translate-y-1/2 z-20 bg-[#1a1a1a]/80 border border-white/10 p-2 rounded-full text-[#ea7601] shadow-lg backdrop-blur-sm opacity-0 transition-opacity"
      aria-label="Next edition"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <div 
      id="pricing-scroller"
      class="flex md:grid md:grid-cols-2 gap-6 md:gap-8 lg:gap-12 overflow-x-auto md:overflow-x-visible snap-x snap-mandatory pb-8 md:pb-0 pricing-scroll-container"
    >
    {
      editions.map((edition) => (
        <div
          data-edition={edition.isPro ? "pro" : "free"}
          class={`relative flex-shrink-0 w-[85vw] md:w-auto snap-center bg-[#1a1a1a] rounded-3xl p-8 md:p-12 overflow-hidden border shadow-2xl transition-all duration-500 flex flex-col ${
            edition.isPro 
              ? "border-2 border-[#ea7601] shadow-[#ea7601]/20 transform md:-translate-y-4" 
              : "border-white/5 hover:border-white/20"
          }`}
        >
          {edition.badge && (
            <div class="absolute top-0 right-0 bg-[#ea7601] text-white px-6 py-2 rounded-bl-3xl font-bold uppercase text-sm tracking-widest shadow-lg">
              {edition.badge}
            </div>
          )}

          {edition.isPro && (
            <div class="absolute top-0 right-0 p-12 opacity-5 scale-150 rotate-12">
              <svg width="200" height="200" viewBox="0 0 24 24" fill="none" class="text-[#ea7601]">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          )}

          <div class="relative z-10 flex flex-col h-full">
            <h3 class="text-3xl font-bold mb-2 uppercase text-white">{edition.name}</h3>
            <div class="text-4xl font-bold text-[#ea7601] mb-8">
              {edition.price} <span class="text-sm text-gray-400 font-normal">{edition.period}</span>
            </div>

            <ul class="space-y-4 mb-12 flex-grow text-gray-300">
              {edition.features.map((feature, featureIdx) => (
                <li class="flex items-start gap-3">
                  <div class={`mt-1 p-1 rounded-full ${edition.isPro && featureIdx === 0 ? "bg-[#ea7601]" : "bg-[#ea7601]/20"}`}>
                    <svg
                      class={`w-4 h-4 ${edition.isPro && featureIdx === 0 ? "text-white" : "text-[#ea7601]"} flex-shrink-0`}
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <span class={edition.isPro && featureIdx === 0 ? "text-white font-semibold" : ""}>{feature}</span>
                </li>
              ))}
            </ul>

            <div class="pt-4 mt-auto">
              <a
                href={edition.href}
                target="_blank"
                rel="noopener noreferrer"
                class={`w-full py-4 flex items-center justify-center gap-3 text-white font-bold rounded-full uppercase tracking-widest transition-all duration-300 shadow-lg ${
                  edition.isPro 
                    ? "bg-[#ea7601] hover:bg-[#ff9a3c] shadow-[#ea7601]/40 hover:-translate-y-1 hover:shadow-xl" 
                    : "bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/10 hover:border-white/20 hover:-translate-y-1"
                } group`}
              >
                {edition.isPro ? (
                  <ShoppingCart className="w-5 h-5 transition-transform group-hover:scale-110" />
                ) : (
                  <Download className="w-5 h-5 transition-transform group-hover:scale-110" />
                )}
                {edition.buttonText}
              </a>
            </div>
          </div>
        </div>
      ))
    }
    </div>
  </div>
</div>

<style>
  .pricing-scroll-container {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }
  .pricing-scroll-container::-webkit-scrollbar {
    display: none; /* Chrome, Safari and Opera */
  }
</style>

<script>
  function initPricingScroll() {
    const scroller = document.getElementById('pricing-scroller');
    const prevBtn = document.getElementById('pricing-prev');
    const nextBtn = document.getElementById('pricing-next');
    const proCard = document.querySelector('[data-edition="pro"]') as HTMLElement;

    if (!scroller || !prevBtn || !nextBtn) return;

    // Show/hide arrows based on scroll position
    const updateArrows = () => {
      if (window.innerWidth >= 768) return;
      
      const scrollLeft = scroller.scrollLeft;
      const maxScroll = scroller.scrollWidth - scroller.clientWidth;
      
      prevBtn.style.opacity = scrollLeft > 10 ? '1' : '0';
      nextBtn.style.opacity = scrollLeft < maxScroll - 10 ? '1' : '0';
    };

    scroller.addEventListener('scroll', updateArrows);
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) {
        prevBtn.style.opacity = '0';
        nextBtn.style.opacity = '0';
      } else {
        updateArrows();
      }
    });

    prevBtn.addEventListener('click', () => {
      scroller.scrollBy({ left: -scroller.clientWidth * 0.8, behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      scroller.scrollBy({ left: scroller.clientWidth * 0.8, behavior: 'smooth' });
    });

    // Initial positioning: Default to Pro version on mobile
    if (window.innerWidth < 768 && proCard) {
      setTimeout(() => {
        const cardOffset = proCard.offsetLeft;
        const scrollerWidth = scroller.clientWidth;
        const cardWidth = proCard.clientWidth;
        
        // Center the Pro card
        scroller.scrollTo({
          left: cardOffset - (scrollerWidth - cardWidth) / 2,
          behavior: 'auto'
        });
        updateArrows();
      }, 100);
    }
    
    updateArrows();
  }

  // Handle Astro page transitions if using ViewTransitions
  document.addEventListener('astro:page-load', initPricingScroll);
  // Initial load
  initPricingScroll();
</script>
