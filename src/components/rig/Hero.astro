---
import Icon from "../ui/Icon.astro";
---

<section
  class="relative h-screen flex items-center justify-center overflow-hidden bg-[#ea7601]"
>
  <!-- Background Image & Overlay -->
  <div class="absolute inset-0">
    <div
      class="absolute inset-0 bg-gradient-to-t from-[#111] via-transparent to-[#111]/30"
    >
    </div>
  </div>

  <!-- Floating decorative particles -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div
      class="absolute top-1/4 left-1/4 w-2 h-2 bg-white/20 rounded-full animate-float"
    >
    </div>
    <div
      class="absolute top-1/3 right-1/3 w-3 h-3 bg-white/10 rounded-full animate-float delay-200"
    >
    </div>
    <div
      class="absolute bottom-1/3 left-1/3 w-1.5 h-1.5 bg-[#ea7601]/30 rounded-full animate-float delay-400"
    >
    </div>
    <div
      class="absolute top-2/3 right-1/4 w-2 h-2 bg-white/15 rounded-full animate-float delay-300"
    >
    </div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto space-y-6">
    <div class="animate-fade-in-up">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm text-white/80 text-sm font-medium mb-6 border border-white/10"
      >
        <span class="w-2 h-2 rounded-full bg-[#ea7601] animate-pulse"></span>
        Next-Gen Minecraft Rig for Blender
      </div>
    </div>
    <h1
      style="font-family: 'Audiowide', sans-serif;"
      class="text-7xl md:text-9xl font-bold tracking-tight text-white drop-shadow-lg uppercase animate-fade-in-up delay-100"
    >
      <span
        class="block text-transparent bg-clip-text bg-gradient-to-b from-white to-white/70"
        >Rig/2</span
      >
    </h1>
    <p
      class="text-xl md:text-2xl text-white/90 max-w-2xl mx-auto font-sans tracking-wide leading-relaxed animate-fade-in-up delay-200"
    >
      Define the New Standard
    </p>
    <p
      class="text-base md:text-lg text-white/60 max-w-xl mx-auto font-sans leading-relaxed animate-fade-in-up delay-300"
    >
      一套为 Blender 打造的终极 Minecraft 角色绑定方案。<br />
      AIO 着色器 · 1:1 控制面板 · 多维形体系统 · MI 动作导入
    </p>
  </div>

  <!-- Scroll Indicator -->
  <a
    href="#stats"
    class="absolute bottom-32 z-10 text-white/50 hover:text-white transition-colors animate-bounce"
    aria-label="Scroll to features"
  >
    <Icon name="chevron-down" className="w-10 h-10" />
  </a>
</section>
