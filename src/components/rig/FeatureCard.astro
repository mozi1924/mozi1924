---
interface Props {
  id: string;
  title: string;
  description: string;
  details: string[];
}

const { id, title, description, details } = Astro.props;
---

<div
  class="relative bg-[#1a1a1a] rounded-3xl p-8 md:p-12 overflow-hidden border border-white/5 shadow-2xl group hover:border-[#ea7601]/50 transition-colors duration-500"
>
  <div
    class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-20 transition-opacity duration-500"
  >
    <div class="text-8xl font-black italic text-[#ea7601]">{id}</div>
  </div>
  <div class="relative z-10">
    <div
      class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#ea7601]/10 text-[#ea7601] text-sm font-medium mb-6"
    >
      MODULE {id}
    </div>
    <h3 class="text-2xl font-bold mb-4 uppercase tracking-wide text-white">
      {title}
    </h3>
    <p class="text-gray-400 leading-relaxed mb-4">
      {description}
    </p>
    <ul class="space-y-2 text-gray-500 text-sm">
      {
        details.map((detail) => (
          <li class="flex items-center gap-2">
            <span class="w-1 h-1 rounded-full bg-[#ea7601]" />
            {detail}
          </li>
        ))
      }
    </ul>
  </div>
</div>
