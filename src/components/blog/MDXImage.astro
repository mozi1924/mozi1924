---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata | string;
  alt?: string;
  width?: number | string;
  height?: number | string;
  class?: string;
  style?: string;
  [key: string]: unknown;
}

const { src, alt = "", ...rest } = Astro.props;
---

{typeof src === "object" && src !== null ? (
  <Image
    src={src as ImageMetadata}
    alt={alt}
    loading="lazy"
    decoding="async"
    {...rest}
  />
) : (
  <img
    src={src as string}
    alt={alt}
    loading="lazy"
    decoding="async"
    {...rest}
  />
)}
