---
import Lightbox from "./react/Lightbox.jsx";
import { getImage } from "astro:assets";

// Import original images
import dbhImg from "../../assets/showcase/dbh-max.webp";
import rig1Img from "../../assets/showcase/rig-one.webp";
import nodusImg from "../../assets/showcase/nodus.webp";

// Showcase Data
const rawItems = [
    {
        title: "Become Human",
        date: "2025-5-21",
        description:
            "This is a short animation that imitates the opening sequence of the game *Detroit: Become Human*, used to showcase the flexibility of my rigging and the material effects of the skin texture.",
        button: {
            text: "Watch Video",
            url: "https://www.youtube.com/watch?v=XxAqKosI6ZE",
        },
        image: dbhImg,
    },
    {
        title: "Rig/1",
        date: "2025-8-18",
        description:
            "A custom rig for Minecraft that allows for easy animation and rigging.",
        button: {
            text: "Learn More",
            url: "https://rig-doc.mozi1924.com/",
        },
        image: rig1Img,
    },
    {
        title: "NOW SHUT UP AND DRIVE 2.0",
        date: "2025-11-14",
        description:
            "A demonstration showcasing my powerful video keypoint tracking and synthesis capabilities, featuring captivating dance and music.",
        button: {
            text: "Watch Video",
            url: "https://www.bilibili.com/video/BV1mjCuByEHR",
        },
        image: nodusImg,
    },
];

// Optimize images for thumbnail and full display
const optimizedItems = await Promise.all(
    rawItems.map(async (item) => {
        const thumbnail = await getImage({
            src: item.image,
            width: 800,
            format: "webp",
            quality: 80,
        });
        const fullSize = await getImage({
            src: item.image,
            width: 1600,
            format: "webp",
            quality: 90,
        });
        return {
            ...item,
            thumbnail: thumbnail.src,
            fullSize: fullSize.src,
        };
    })
);
---

<section class="py-24 bg-[#161616] px-6">
    <div class="max-w-[1600px] mx-auto space-y-16">
        <div class="text-center space-y-4">
            <h2 class="text-3xl font-bold text-white">Showcase</h2>
            <div class="w-20 h-1 bg-white mx-auto rounded-full"></div>
        </div>

        <Lightbox client:load items={optimizedItems} />
    </div>
</section>
