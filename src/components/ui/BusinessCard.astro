---
import Icon from "./Icon.astro";
import { Image } from "astro:assets";
import { AUTHORS, DEFAULT_AUTHOR_ID } from "../../config";

interface Props {
  authorId?: string;
  name?: string;
  avatar?: string | any; // allow image metadata or string
  motto?: string;
  socials?: {
    network: string;
    url: string;
    icon?: string;
  }[];
}

const props = Astro.props;
const authorId = props.authorId || DEFAULT_AUTHOR_ID;
const author = AUTHORS[authorId] || AUTHORS[DEFAULT_AUTHOR_ID];

const {
  name = author.name,
  avatar = author.avatar,
  motto = author.motto,
  socials = author.socialLinks,
} = props;

const getIconName = (network: string) => {
  switch (network.toLowerCase()) {
    case "github":
      return "GH";
    case "twitter":
      return "X";
    case "youtube":
      return "YT";
    case "email":
      return "@";
    case "linkedin":
      return "IN";
    case "facebook":
      return "f";
    case "instagram":
      return "IG";
    default:
      return null;
  }
};
---

<div
  class="bg-[#1a1a1a] rounded-2xl border border-white/10 p-6 flex flex-col items-center text-center shadow-xl"
>
  <!-- Avatar -->
  <div class="relative w-32 h-32 mb-4 group">
    <div
      class="absolute inset-0 bg-blue-500 rounded-full blur opacity-20 group-hover:opacity-40 transition-opacity duration-500"
    >
    </div>
    <Image
      src={avatar}
      alt={`${name} Avatar`}
      width={128}
      height={128}
      class="relative w-full h-full rounded-full object-cover border-2 border-white/10 group-hover:border-blue-500/50 transition-colors duration-300"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- Name & Motto -->
  <h2 class="text-2xl font-bold text-white mb-2">{name}</h2>
  <p class="text-gray-400 text-sm mb-6 leading-relaxed">
    {motto}
  </p>

  <!-- Divider -->
  <div class="w-full h-px bg-white/10 mb-6"></div>

  <!-- Social Links -->
  <div class="flex flex-col w-full gap-3">
    {
      socials.map((social) => {
        const iconName = getIconName(social.network);
        const isEmail = social.network.toLowerCase() === "email";
        return (
          <a
            href={social.url}
            target={isEmail ? undefined : "_blank"}
            rel={isEmail ? undefined : "noopener noreferrer"}
            class="flex items-center gap-3 p-3 rounded-xl bg-white/5 hover:bg-white/10 transition-colors group"
          >
            <div class="text-gray-400 group-hover:text-white transition-colors w-5 h-5 flex items-center justify-center">
              {iconName ? (
                <span class="text-[10px] font-bold leading-none">{iconName}</span>
              ) : isEmail ? (
                <Icon name="mail" className="w-5 h-5" />
              ) : (
                <Icon name="globe" className="w-5 h-5" />
              )}
            </div>
            <span class="text-sm text-gray-300 font-medium group-hover:text-white">
              {social.network}
            </span>
          </a>
        );
      })
    }
  </div>
</div>
