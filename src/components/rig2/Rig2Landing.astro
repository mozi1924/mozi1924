---
import FeetComparisonSlider from "./FeetComparisonSlider";

import madeForPro from "../../assets/rig2/made-for-pro.webp";
import feetNone from "../../assets/rig2/feet-none.webp";
import feetStandard from "../../assets/rig2/feet-standard.webp";
import feetFancy from "../../assets/rig2/feet-fancy.webp";
import aioShader from "../../assets/rig2/aio_shader.webp";
import nodeShaderEye from "../../assets/rig2/node_shader_eye.webp";
import faceCap from "../../assets/rig2/face_cap.webp";
import nativeIntegration from "../../assets/rig2/Native_Integration.webp";

const feetModes = [
  {
    label: "No Ankles",
    caption: "最简洁的轮廓，适合追求干净体块和快速出镜的镜头。",
    image: feetNone.src,
  },
  {
    label: "Standard",
    caption: "保留标准脚踝层次，在兼顾辨识度和易用性的同时维持熟悉手感。",
    image: feetStandard.src,
  },
  {
    label: "Fancy Feet",
    caption: "给近景和走位更多层次，适合希望脚步表现更完整的角色演出。",
    image: feetFancy.src,
  },
];

const signalPoints = [
  { value: "1", label: "AIO shader tree" },
  { value: "3", label: "feet looks in one rig" },
  { value: "Live", label: "face capture ready" },
  { value: "MI", label: "animation bridge" },
];

const ecosystemStories = [
  {
    eyebrow: "Expression",
    title: "More believable close-ups",
    body:
      "新的表情与眼部控制让角色在近景里更能撑住情绪，既能做干净的卡通感，也能留出细腻微调的空间。",
    image: nodeShaderEye,
    imageClass: "is-hero-wide",
  },
  {
    eyebrow: "Ecosystem",
    title: "A wider route from Mine-imator to Blender",
    body:
      "Rig/2 现在不只是一个绑定文件。配合生态工具，你可以把 Mine-imator 里的动作思路继续带进 Blender，再接着打磨、重定节奏、完成镜头。",
    image: nativeIntegration,
    imageClass: "is-tall-side",
  },
  {
    eyebrow: "Realtime",
    title: "Face capture joins the rig naturally",
    body:
      "面部捕捉不再像额外挂件，而是更像直接接进 Rig/2 的控制层。做预演、录参考、快速找表情都更顺手。",
    image: faceCap,
    imageClass: "is-medium-wide",
  },
  {
    eyebrow: "Shader",
    title: "One shader, less interruption",
    body:
      "皮肤、眼睛和常见细节尽量收进同一套节点逻辑里，换肤和调整材质不再打断节奏，镜头前后也更容易保持一致。",
    image: aioShader,
    imageClass: "is-compact",
  },
];

const workflow = [
  {
    step: "01",
    title: "Append the rig",
    body: "把 Rig/2 拉进场景后，角色骨架、控制习惯和材质组织就一起到位。",
  },
  {
    step: "02",
    title: "Dress the character fast",
    body: "换皮肤、切脚部风格、调形体和眼部细节，都在更集中的一套入口里完成。",
  },
  {
    step: "03",
    title: "Bring performance in",
    body: "需要时直接接上 face capture，或者把 Mine-imator 的动作继续带进 Blender 细修。",
  },
  {
    step: "04",
    title: "Stay in the shot",
    body: "从预演到最终镜头尽量少换工具和少打断，让创作时间更多留给动作和表演。",
  },
];

const editions = [
  {
    name: "Free Edition",
    summary: "适合先把角色、材质和基础动画工作流跑起来。",
    cta: "Download Free",
    href: "https://assets.mozi1924.com/rig2/latest.zip",
    points: [
      "Rig/2 核心绑定",
      "AIO 着色器",
      "三种脚部模式",
      "Steve / Alex 支持",
      "个人与非商业创作",
    ],
  },
  {
    name: "Pro Track",
    summary: "面向更完整的表演工作流，目前仍在持续扩展中。",
    cta: "In Development",
    href: null,
    points: [
      "包含生态工具能力方向",
      "Face capture 集成",
      "更完整的动作导入路线",
      "原生模块分发准备",
      "商业授权计划",
    ],
  },
];
---

<div class="rig2-page">
  <section class="rig2-hero">
    <div class="hero-media">
      <img src={madeForPro.src} alt="Rig/2 character showcase" loading="eager" />
      <div class="hero-media-glow"></div>
    </div>

    <div class="hero-copy">
      <p class="hero-kicker">Blender Minecraft Character System</p>
      <h1>Rig/2</h1>
      <p class="hero-subhead">A cleaner character rig with a wider animation pipeline.</p>
      <p class="hero-body">
        从角色搭建、脚部风格切换，到面部驱动和 Mine-imator 工作流延伸，
        Rig/2 正在从一份绑定成长为一套更完整的 Blender 动画入口。
      </p>

      <div class="hero-actions">
        <a href="https://assets.mozi1924.com/rig2/latest.zip" target="_blank" rel="noopener noreferrer" class="hero-button is-primary">
          Download Free
        </a>
        <a href="/blogs/rig2-ecosystem-dev-months/" class="hero-button is-secondary">
          Read the ecosystem story
        </a>
      </div>

      <div class="hero-signals">
        {
          signalPoints.map((item) => (
            <div class="signal">
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="rig2-section section-intro">
    <div class="section-heading">
      <p class="eyebrow">Feet System</p>
      <h2>One rig, three different silhouettes.</h2>
      <p>
        `feet-*` 这一组新图不是简单展示，而是直接做成可拖动的三态对比。
        你可以在同一个镜头尺度里直观看到 No Ankles、Standard 和 Fancy Feet 的差异。
      </p>
    </div>

    <FeetComparisonSlider items={feetModes} client:only="react" />
  </section>

  <section class="rig2-section ecosystem-grid">
    <div class="section-heading">
      <p class="eyebrow">What Changed</p>
      <h2>Rig/2 now covers more of the performance chain.</h2>
      <p>
        新功能不只是“再多几个按钮”，而是把角色塑形、实时输入、动作承接和后续扩展逐渐收拢到同一条创作路径里。
      </p>
    </div>

    <div class="story-grid">
      {
        ecosystemStories.map((story) => (
          <article class={`story-block ${story.imageClass}`}>
            <div class="story-copy">
              <p class="story-eyebrow">{story.eyebrow}</p>
              <h3>{story.title}</h3>
              <p>{story.body}</p>
            </div>
            <div class="story-media">
              <img src={story.image.src} alt={story.title} loading="lazy" />
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="rig2-section workflow-section">
    <div class="section-heading">
      <p class="eyebrow">Workflow</p>
      <h2>Built for staying inside the creative loop.</h2>
      <p>
        新页面不再把重点放在参数列表，而是把最重要的一件事说清楚:
        Rig/2 想做的是让角色设置、表演和动画承接尽量发生在同一条顺手的路径上。
      </p>
    </div>

    <div class="workflow-track">
      {
        workflow.map((item) => (
          <div class="workflow-step">
            <span>{item.step}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="rig2-section editions-section">
    <div class="section-heading">
      <p class="eyebrow">Editions</p>
      <h2>Start free, grow into the wider ecosystem.</h2>
      <p>
        现在就可以先从核心绑定开始，后续再按需要接入更完整的工作流能力。
      </p>
    </div>

    <div class="editions-grid">
      {
        editions.map((edition) => (
          <article class="edition-block">
            <div>
              <h3>{edition.name}</h3>
              <p class="edition-summary">{edition.summary}</p>
            </div>

            <ul>
              {edition.points.map((point) => <li>{point}</li>)}
            </ul>

            {edition.href ? (
              <a
                href={edition.href}
                target="_blank"
                rel="noopener noreferrer"
                class="hero-button is-primary edition-button"
              >
                {edition.cta}
              </a>
            ) : (
              <span class="hero-button is-secondary edition-button is-disabled">{edition.cta}</span>
            )}
          </article>
        ))
      }
    </div>

    <div class="footer-note">
      <p>Started at 2025-10-09. Current page refreshed for the newer Rig/2 feature set.</p>
      <p>* 具体视口表现仍会随硬件与 Blender 场景设置变化。</p>
      <a href="/mozi-rig/legacy">Need the legacy release instead?</a>
    </div>
  </section>
</div>

<style is:global>
  .rig2-page {
    --rig2-bg: #0f0f0c;
    --rig2-panel: rgba(250, 245, 237, 0.05);
    --rig2-line: rgba(255, 255, 255, 0.1);
    --rig2-soft: rgba(255, 255, 255, 0.66);
    --rig2-accent: #f17d18;
    --rig2-accent-soft: #ffb36c;
    --rig2-ink: #faf5ed;
    background:
      radial-gradient(circle at top left, rgba(241, 125, 24, 0.18), transparent 34%),
      radial-gradient(circle at right 20%, rgba(255, 179, 108, 0.12), transparent 22%),
      linear-gradient(180deg, #16120d 0%, #0f0f0c 48%, #0c0c0a 100%);
    color: var(--rig2-ink);
  }

  .rig2-hero,
  .rig2-section {
    width: min(1220px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .rig2-hero {
    min-height: calc(100svh - 4rem);
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
    padding: clamp(2.5rem, 4vw, 4rem) 0 4rem;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    max-width: 33rem;
  }

  .hero-kicker,
  .eyebrow,
  .story-eyebrow {
    margin: 0 0 1rem;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }

  .hero-copy h1 {
    margin: 0;
    font-family: "Audiowide", sans-serif;
    font-size: clamp(4rem, 12vw, 8rem);
    line-height: 0.94;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  .hero-subhead {
    margin: 1.5rem 0 0;
    font-size: clamp(1.4rem, 2.6vw, 2.35rem);
    line-height: 1.05;
    max-width: 12ch;
  }

  .hero-body,
  .section-heading p,
  .story-copy p,
  .workflow-step p,
  .edition-summary,
  .footer-note p,
  .comparison-caption {
    color: var(--rig2-soft);
    line-height: 1.7;
    font-size: 1rem;
  }

  .hero-body {
    max-width: 30rem;
    margin: 1.25rem 0 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0 1.35rem;
    border-radius: 999px;
    border: 1px solid var(--rig2-line);
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .hero-button:hover {
    transform: translateY(-1px);
  }

  .hero-button.is-primary {
    background: linear-gradient(135deg, var(--rig2-accent), var(--rig2-accent-soft));
    color: #140d07;
    border-color: transparent;
    font-weight: 700;
  }

  .hero-button.is-secondary {
    background: rgba(255, 255, 255, 0.04);
    color: var(--rig2-ink);
  }

  .hero-button.is-disabled {
    opacity: 0.72;
    pointer-events: none;
  }

  .hero-signals {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2.3rem;
  }

  .signal {
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .signal strong {
    display: block;
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    color: white;
  }

  .signal span {
    display: block;
    margin-top: 0.35rem;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.82rem;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-media {
    position: relative;
    min-height: 32rem;
    height: min(80svh, 54rem);
    border-radius: 2rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
  }

  .hero-media img,
  .story-media img,
  .comparison-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-media-glow {
    position: absolute;
    inset: auto 0 0 0;
    height: 45%;
    background: linear-gradient(180deg, transparent, rgba(7, 6, 4, 0.92));
  }

  .rig2-section {
    padding: clamp(4rem, 8vw, 7rem) 0;
  }

  .section-heading {
    display: grid;
    gap: 0.75rem;
    max-width: 42rem;
    margin-bottom: 2.2rem;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .section-intro {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .feet-comparison {
    display: grid;
    gap: 1rem;
  }

  .comparison-stage {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 1.8rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    touch-action: none;
    user-select: none;
  }

  .comparison-layer {
    position: absolute;
    inset: 0;
  }

  .comparison-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2.5rem;
    transform: translateX(-50%);
    background: transparent;
    border: 0;
    padding: 0;
    cursor: ew-resize;
    opacity: 0.92;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .comparison-handle.is-dragging {
    transform: translateX(-50%) scale(1.06);
    opacity: 1;
  }

  .comparison-handle-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 0 24px rgba(255, 255, 255, 0.25);
  }

  .comparison-handle-pill {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 2.1rem;
    height: 3.3rem;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    background: rgba(10, 10, 9, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.18);
    display: grid;
    place-items: center;
    gap: 0.2rem;
    align-content: center;
  }

  .comparison-handle-pill span {
    width: 0.18rem;
    height: 0.95rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
  }

  .comparison-badges {
    position: absolute;
    inset: 0.65rem 0 auto;
    height: 0;
    pointer-events: none;
  }

  .comparison-badge {
    position: absolute;
    transform: translateX(-50%);
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    background: rgba(10, 10, 9, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .comparison-copy {
    display: grid;
    gap: 0.85rem;
  }

  .comparison-caption-live {
    animation: comparisonCaptionIn 220ms ease-out;
  }

  .comparison-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .comparison-tab {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.03);
    color: rgba(255, 255, 255, 0.7);
    border-radius: 999px;
    min-height: 2.8rem;
    padding: 0 1rem;
  }

  .comparison-tab.is-active {
    color: #1a120a;
    background: linear-gradient(135deg, var(--rig2-accent), var(--rig2-accent-soft));
    border-color: transparent;
  }

  .story-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
  }

  .story-block {
    display: grid;
    gap: 1rem;
    padding: 1rem;
    border-radius: 1.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.02));
  }

  .story-block.is-hero-wide {
    grid-column: 1 / span 8;
  }

  .story-block.is-tall-side {
    grid-column: 9 / span 4;
    grid-row: span 2;
    grid-template-rows: auto minmax(0, 1fr);
  }

  .story-block.is-medium-wide {
    grid-column: 1 / span 5;
  }

  .story-block.is-compact {
    grid-column: 6 / span 3;
  }

  .story-copy {
    padding: 0.55rem;
  }

  .story-copy h3,
  .workflow-step h3,
  .edition-block h3 {
    margin: 0 0 0.8rem;
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .story-media {
    min-height: 18rem;
    border-radius: 1.25rem;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.16);
  }

  .story-block.is-hero-wide .story-media,
  .story-block.is-medium-wide .story-media {
    min-height: 20rem;
  }

  .story-block.is-tall-side .story-media {
    min-height: 100%;
  }

  .story-block.is-compact .story-media {
    min-height: 16rem;
  }

  .story-block.is-compact .story-media img {
    object-fit: contain;
    padding: 1.5rem;
    background: radial-gradient(circle at center, rgba(241, 125, 24, 0.15), transparent 65%);
  }

  .workflow-track,
  .editions-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .workflow-step,
  .edition-block {
    padding: 1.35rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .workflow-step span {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--rig2-accent-soft);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
  }

  .edition-block {
    display: grid;
    gap: 1.25rem;
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }

  .edition-block ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.75rem;
  }

  .edition-block li {
    position: relative;
    padding-left: 1rem;
    color: var(--rig2-soft);
  }

  .edition-block li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 999px;
    background: var(--rig2-accent);
  }

  .edition-button {
    width: fit-content;
  }

  .footer-note {
    display: grid;
    gap: 0.6rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-note a {
    color: var(--rig2-ink);
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }

  @keyframes comparisonCaptionIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 960px) {
    .rig2-hero {
      grid-template-columns: 1fr;
      padding-top: 1.75rem;
    }

    .hero-copy {
      max-width: none;
      order: 1;
    }

    .hero-media {
      order: 2;
      min-height: 22rem;
      height: 60svh;
    }

    .hero-signals,
    .workflow-track,
    .editions-grid,
    .story-block.is-hero-wide,
    .story-block.is-tall-side,
    .story-block.is-medium-wide,
    .story-block.is-compact {
      grid-template-columns: 1fr;
      grid-column: span 12;
    }

    .story-block.is-tall-side {
      grid-template-columns: 1fr;
      grid-row: auto;
    }
  }

  @media (max-width: 720px) {
    .rig2-hero,
    .rig2-section {
      width: min(100% - 1rem, 1220px);
    }

    .hero-copy h1 {
      font-size: clamp(3.3rem, 24vw, 5.4rem);
    }

    .hero-subhead {
      max-width: none;
    }

    .hero-signals {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .comparison-stage {
      border-radius: 1.2rem;
    }

    .comparison-badge {
      font-size: 0.62rem;
      padding: 0.35rem 0.55rem;
    }

