---
import Layout from "../layouts/Layout.astro";
import RigStyles from "../components/rig/RigStyles.astro";
import Rig2Landing from "../components/rig2/Rig2Landing.astro";

const customTitle = "Rig/2 - A Cleaner Character Rig";
const customDescription =
  "Rig/2 is a Blender-ready Minecraft character system with a cleaner shader workflow, three feet styles, face capture direction, and a wider animation ecosystem.";
---

<Layout title={customTitle} description={customDescription}>
  <RigStyles />
  <Rig2Landing />
</Layout>
